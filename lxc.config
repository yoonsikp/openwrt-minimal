# PACKAGES: parted kmod-fs-exfat exfat-mkfs block-mount blkid nano kmod-veth kmod-tun luci-app-lxc lxc-start lxc-stop lxc-destroy kmod-sound-hda-codec-hdmi
# 

# Command to create Debian LXC Container
# lxc-create -n jellyfin -t download -- -d debian -r trixie -a amd64

lxc.net.0.link = br-lan

# Bind GPU driver
lxc.cgroup2.devices.allow = c 226:0 rwm
lxc.cgroup2.devices.allow = c 226:128 rwm
lxc.mount.entry = /dev/dri dev/dri none bind,optional,create=dir

# Bind external mounts
lxc.mount.entry = /mnt/media mnt/media none bind,create=dir

# Bind tun capability
lxc.cgroup2.devices.allow = c 10:200 rwm
lxc.mount.entry = /dev/net/tun dev/net/tun none bind,create=file

# Bind framebuffer 
lxc.cgroup2.devices.allow = c 29:* rwm
lxc.mount.entry = /dev/fb0 dev/fb0 none bind,optional,create=file

# Bind sound
lxc.cgroup2.devices.allow = c 116:* rwm
lxc.mount.entry = /dev/snd dev/snd none bind,optional,create=dir
